# Cursor Cloud Agents API — image generation backend (cursor.com/settings → API keys)
CURSOR_API_KEY=
# Optional: GitHub repo the render agents are linked to (must be connected to
# Cursor's GitHub app). Leave empty (or "none") to run repo-less render agents
# — same speed and quality, one less dependency.
CURSOR_REPO=
# Agent model used for image generation (cheap + capable default; fastest of
# the plan-available options in live tests). If your plan has access to
# claude-opus-4-8, it measured ~2x faster per render with the best fidelity
# (experiments/model-comparison/RESULTS.md). "default" = Cursor Auto routing.
# List valid ids: node experiments/model-comparison/run.mjs --list
CURSOR_MODEL=composer-2.5

# Stripe keys (test keys start with sk_test / pk_test)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe webhook signing secret (from `stripe listen` or the dashboard) — optional but recommended in production
STRIPE_WEBHOOK_SECRET=

# Absolute URL of the site, used for Stripe redirects AND for the signed
# /api/render-input URLs the render agents curl to fetch the room photo
# (agent-attached images aren't files on the agent VM). Must be public https
# in production; on localhost the pipeline falls back to attachment-only.
# No trailing slash.
# Local: http://localhost:3000
# Production: https://stagely.org
SITE_URL=http://localhost:3000

# Optional: HMAC secret for signing /api/render-input URLs. If unset, a
# random secret is generated and persisted at data/render-input.secret.
RENDER_INPUT_SECRET=

# Resend API key for sign-in code emails (free tier: resend.com).
# If unset, the code is shown on the sign-in page in dev instead.
RESEND_API_KEY=
EMAIL_FROM=Stagely <hello@stagely.org>

# Set to 1 to fake generation locally (tinted copy, no agent credits used)
MOCK_GENERATION=0
# When MOCK_GENERATION=1, simulated render latency in ms (so background progress
# is visible while developing). Set 0 for instant mock renders.
MOCK_DELAY_MS=6000
